{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Ofox App",
  "description": "Schema for apps that work with Ofox",
  "type": "object",
  "required": ["name", "description", "url", "docs", "tags", "date_added"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "应用名称"
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 300,
      "description": "一句话介绍（1-2 句，最多 300 字符）"
    },
    "url": {
      "type": "string",
      "format": "uri",
      "pattern": "^https?://",
      "description": "应用链接"
    },
    "docs": {
      "type": "string",
      "format": "uri",
      "pattern": "^https?://",
      "description": "Ofox 集成文档链接（选填）"
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["chat", "coding", "productivity", "creative", "research", "education", "data", "media", "devops", "other"]
      },
      "description": "分类标签"
    },
    "open_source": {
      "type": "string",
      "format": "uri",
      "pattern": "^https?://",
      "description": "开源仓库地址（选填）"
    },
    "date_added": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "添加日期 YYYY-MM-DD"
    }
  }
}
